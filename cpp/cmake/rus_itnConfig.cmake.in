@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
set(_rus_itn_saved_module_path "${CMAKE_MODULE_PATH}")
list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")
find_dependency(OpenFST)
set(CMAKE_MODULE_PATH "${_rus_itn_saved_module_path}")
unset(_rus_itn_saved_module_path)

include("${CMAKE_CURRENT_LIST_DIR}/rus_itnTargets.cmake")
check_required_components(rus_itn)
